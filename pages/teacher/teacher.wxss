.page {
  padding: 28rpx;
}

.profile,
.card {
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(39, 63, 60, .08);
}

.profile {
  padding: 30rpx;
  display: flex;
  gap: 24rpx;
  align-items: center;
}

.avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: #1f5f5b;
  color: #fff;
  font-size: 52rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 40rpx;
  font-weight: 900;
}

.title {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #b94438;
  font-weight: 800;
}

.desc,
.detail {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #596966;
}

.card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
}

.detail {
  display: block;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f0e8;
  color: #66543b;
  font-size: 24rpx;
}
