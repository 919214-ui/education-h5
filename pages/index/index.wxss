.page {
  padding: 28rpx 28rpx 44rpx;
}

.hero {
  min-height: 360rpx;
  padding: 36rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #b94438 0%, #d88435 48%, #1f5f5b 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-text {
  width: 66%;
  display: flex;
  flex-direction: column;
}

.eyebrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, .82);
}

.hero-title {
  margin-top: 18rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, .9);
}

.coupon {
  width: 150rpx;
  height: 180rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, .95);
  color: #b94438;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 44rpx rgba(50, 27, 18, .2);
}

.coupon-top {
  font-size: 24rpx;
  color: #7b5b2a;
}

.coupon-main {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.teacher-list {
  display: flex;
  gap: 14rpx;
}

.teacher-mini {
  flex: 1;
  min-height: 156rpx;
  padding: 18rpx 10rpx;
  border-radius: 8rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(39, 63, 60, .08);
}

.teacher-avatar {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  background: #1f5f5b;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
}

.teacher-short {
  margin-top: 10rpx;
  font-size: 25rpx;
  font-weight: 800;
  color: #172322;
}

.teacher-role {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #596966;
}

.media-list {
  display: flex;
  gap: 14rpx;
}

.media-card {
  flex: 1;
  min-height: 156rpx;
  padding: 18rpx 10rpx;
  border-radius: 8rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(39, 63, 60, .08);
}

.media-avatar {
  width: 74rpx;
  height: 74rpx;
  border-radius: 8rpx;
  background: #fff0e7;
  color: #b94438;
  font-size: 30rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.media-name {
  margin-top: 10rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.media-desc {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #596966;
}

.section-head {
  margin: 34rpx 0 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 900;
}

.section-subtitle {
  font-size: 22rpx;
  color: #697a77;
}

.category-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.category-card {
  min-height: 220rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #fff;
  display: flex;
  gap: 22rpx;
  box-shadow: 0 8rpx 28rpx rgba(39, 63, 60, .08);
}

.category-cover {
  width: 144rpx;
  height: 176rpx;
  border-radius: 8rpx;
  background: #f3f0e8;
  color: #b94438;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 58rpx;
  font-weight: 900;
}

.category-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.category-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-name {
  font-size: 32rpx;
  font-weight: 900;
  color: #172322;
}

.badge {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #fff0e7;
  color: #b94438;
  font-size: 20rpx;
}

.category-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #596966;
}

.category-bottom {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.school-count {
  font-size: 22rpx;
  color: #8a6a36;
}

.arrow {
  font-size: 24rpx;
  font-weight: 800;
  color: #1f5f5b;
}
