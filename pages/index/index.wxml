<view class="page">
  <view class="hero">
    <view class="hero-text">
      <text class="eyebrow">学历提升商城</text>
      <text class="hero-title">{{org.name}}</text>
      <text class="hero-desc">{{org.desc}}</text>
    </view>
    <view class="coupon">
      <text class="coupon-top">规划</text>
      <text class="coupon-main">1对1</text>
    </view>
  </view>

  <view class="section-head">
    <text class="section-title">学历规划师团队</text>
    <text class="section-subtitle">点击查看详情</text>
  </view>

  <view class="teacher-list">
    <view wx:for="{{teachers}}" wx:key="id" class="teacher-mini" data-id="{{item.id}}" bindtap="goTeacher">
      <view class="teacher-avatar">{{item.avatar}}</view>
      <text class="teacher-short">{{item.name}}</text>
      <text class="teacher-role">{{item.title}}</text>
    </view>
  </view>

  <view class="section-head">
    <text class="section-title">新媒体账号</text>
    <text class="section-subtitle">点击查看展示</text>
  </view>

  <view class="media-list">
    <view wx:for="{{mediaAccounts}}" wx:key="id" class="media-card" data-id="{{item.id}}" bindtap="goMedia">
      <view class="media-avatar">{{item.avatar}}</view>
      <text class="media-name">{{item.name}}</text>
      <text class="media-desc">{{item.handle}}</text>
    </view>
  </view>

  <view class="section-head">
    <text class="section-title">选择项目</text>
    <text class="section-subtitle">点击进入学校列表</text>
  </view>

  <view class="category-grid">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="category-card"
      data-id="{{item.id}}"
      bindtap="goSchools"
    >
      <view class="category-cover">{{item.cover}}</view>
      <view class="category-info">
        <view class="category-row">
          <text class="category-name">{{item.name}}</text>
          <text class="badge">{{item.badge}}</text>
        </view>
        <text class="category-desc">{{item.desc}}</text>
        <view class="category-bottom">
          <text class="school-count">{{item.schools.length}}所学校可选</text>
          <text class="arrow">进入</text>
        </view>
      </view>
    </view>
  </view>
</view>
