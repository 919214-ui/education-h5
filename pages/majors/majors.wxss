.page {
  padding: 28rpx 28rpx 44rpx;
}

.top-banner {
  padding: 32rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #b94438 0%, #d88435 100%);
  color: #fff;
  display: flex;
  flex-direction: column;
}

.crumb {
  font-size: 22rpx;
  color: rgba(255, 255, 255, .78);
}

.title {
  margin-top: 16rpx;
  font-size: 44rpx;
  font-weight: 900;
}

.desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, .9);
}

.major-list {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.major-card {
  padding: 28rpx;
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(39, 63, 60, .08);
}

.major-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.major-name {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
}

.major-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: #596966;
}

.price {
  flex: 0 0 auto;
  font-size: 38rpx;
  font-weight: 900;
  color: #b94438;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f0e8;
  color: #66543b;
  font-size: 22rpx;
}

.detail-block {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #f8faf9;
}

.detail-title {
  display: block;
  font-size: 27rpx;
  font-weight: 900;
}

.detail-text {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #485956;
}

.service-row {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.service {
  flex: 1;
  font-size: 23rpx;
  color: #8a6a36;
}

.consult-button {
  width: 150rpx;
  height: 68rpx;
  border-radius: 8rpx;
  background: #b94438;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}
