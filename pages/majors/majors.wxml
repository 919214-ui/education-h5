<view class="page" wx:if="{{school}}">
  <view class="top-banner">
    <text class="crumb">{{category.name}} / {{school.name}}</text>
    <text class="title">{{level}}专业选择</text>
    <text class="desc">以下为该学校当前层次可选专业，包含简介、价格和服务详情。</text>
  </view>

  <view class="major-list">
    <view wx:for="{{majors}}" wx:key="id" class="major-card" data-id="{{item.id}}" bindtap="goDetail">
      <view class="major-head">
        <view>
          <text class="major-name">{{item.name}}</text>
          <text class="major-desc">{{item.desc}}</text>
        </view>
        <text class="price">{{item.selectedPrice.price}}</text>
      </view>
      <view class="tags">
        <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
      <view class="service-row">
        <text class="service">{{item.selectedPrice.service}}</text>
        <text class="consult-button">看详情</text>
      </view>
    </view>
  </view>
</view>
