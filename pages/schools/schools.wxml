<view class="page" wx:if="{{category}}">
  <swiper wx:if="{{bannerSlides.length}}" class="top-banner" indicator-dots autoplay circular interval="3600">
    <swiper-item wx:for="{{bannerSlides}}" wx:key="imageUrl">
      <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
      <view wx:if="{{item.title || item.desc}}" class="banner-caption">
        <text class="title">{{item.title}}</text>
        <text class="desc">{{item.desc}}</text>
      </view>
    </swiper-item>
  </swiper>

  <view class="section-head">
    <text class="section-title">选择学校</text>
    <text class="section-subtitle">点击学校进入层次选择</text>
  </view>

  <view class="school-grid">
    <view
      wx:for="{{schools}}"
      wx:key="id"
      class="school-card"
      data-school-id="{{item.id}}"
      bindtap="goLevels"
    >
      <view class="school-cover">校</view>
      <view class="school-copy">
        <view class="school-row">
          <text class="school-title">{{item.name}}</text>
          <text class="school-tag">{{item.tag}}</text>
        </view>
        <text class="school-intro">{{item.intro}}</text>
        <view class="school-bottom">
          <text>{{item.majors.length}}个专业方向</text>
          <text class="detail-link">选择层次</text>
        </view>
      </view>
    </view>
  </view>
</view>
