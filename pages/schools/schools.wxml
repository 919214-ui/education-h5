<view class="page" wx:if="{{category}}">
  <view class="top-banner">
    <text class="crumb">首页 / {{category.name}}</text>
    <text class="title">{{category.name}}</text>
    <text class="desc">{{category.desc}}</text>
  </view>

  <view class="section-head">
    <text class="section-title">选择学校</text>
    <text class="section-subtitle">点击学校进入层次选择</text>
  </view>

  <view class="school-grid">
    <view
      wx:for="{{schools}}"
      wx:key="id"
      class="school-card"
      data-school-id="{{item.id}}"
      bindtap="goLevels"
    >
      <view class="school-cover">校</view>
      <view class="school-copy">
        <view class="school-row">
          <text class="school-title">{{item.name}}</text>
          <text class="school-tag">{{item.tag}}</text>
        </view>
        <text class="school-intro">{{item.intro}}</text>
        <view class="school-bottom">
          <text>{{item.majors.length}}个专业方向</text>
          <text class="detail-link">选择层次</text>
        </view>
      </view>
    </view>
  </view>
</view>
