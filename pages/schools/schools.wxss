.page {
  padding: 28rpx 28rpx 44rpx;
}

.top-banner {
  height: 520rpx;
  border-radius: 8rpx;
  background: #fff;
  color: #fff;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

.banner-caption {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 44rpx;
  color: #fff;
  text-shadow: 0 4rpx 22rpx rgba(0, 0, 0, .36);
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
}

.desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, .9);
}

.section-head {
  margin: 34rpx 0 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
}

.section-subtitle {
  font-size: 22rpx;
  color: #697a77;
}

.school-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.school-card {
  min-height: 210rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #fff;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(39, 63, 60, .08);
}

.school-cover {
  width: 138rpx;
  height: 166rpx;
  border-radius: 8rpx;
  background: #f3f0e8;
  color: #b94438;
  font-size: 54rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.school-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.school-row,
.school-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.school-title {
  font-size: 31rpx;
  font-weight: 900;
}

.school-tag {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #fff0e7;
  color: #b94438;
  font-size: 20rpx;
}

.school-intro {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #596966;
}

.school-bottom {
  margin-top: auto;
  font-size: 22rpx;
  color: #8a6a36;
}

.detail-link {
  font-weight: 900;
  color: #1f5f5b;
}
