<view class="page" wx:if="{{school}}">
  <swiper wx:if="{{bannerSlides.length}}" class="school-hero" indicator-dots autoplay circular interval="3600">
    <swiper-item wx:for="{{bannerSlides}}" wx:key="imageUrl">
      <image class="hero-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
      <view wx:if="{{item.title || item.desc}}" class="hero-caption">
        <text class="caption-title">{{item.title}}</text>
        <text class="caption-desc">{{item.desc}}</text>
      </view>
    </swiper-item>
  </swiper>

  <view class="school-summary">
    <text class="school-name">{{school.name}}</text>
    <text class="school-desc">{{school.intro}}</text>
  </view>

  <view wx:for="{{groups}}" wx:key="level">
    <view class="section-head">
      <text class="section-title">{{item.level}}专业</text>
      <text class="section-subtitle">{{item.majors.length}}个可选</text>
    </view>

    <view class="major-list">
      <view wx:for="{{item.majors}}" wx:for-item="major" wx:key="id" class="major-card" data-id="{{major.id}}" data-level="{{item.level}}" bindtap="goMajor">
        <view class="major-main">
          <text class="major-name">{{major.name}}</text>
          <text class="major-desc">{{major.desc}}</text>
        </view>
        <view class="major-side">
          <text class="price">{{major.selectedPrice.price}}</text>
          <text class="detail-link">详情</text>
        </view>
      </view>
      <view wx:if="{{!item.majors.length}}" class="empty">暂无{{item.level}}专业</view>
    </view>
  </view>
</view>
