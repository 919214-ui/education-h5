<view class="page" wx:if="{{school}}">
  <view class="school-hero">
    <view class="school-logo">{{school.imageLabel}}</view>
    <view class="school-copy">
      <text class="path">{{category.name}}</text>
      <text class="school-name">{{school.name}}</text>
      <text class="school-desc">{{school.intro}}</text>
    </view>
  </view>

  <button class="share-button" open-type="share">分享给学生</button>

  <view class="school-detail">
    <view class="intro-image">{{school.imageLabel}}</view>
    <text class="detail-title">学校介绍</text>
    <text class="detail-text">{{school.detail}}</text>
  </view>

  <view class="section-head">
    <text class="section-title">选择报读层次</text>
    <text class="section-subtitle">下一步查看专业和价格</text>
  </view>

  <view class="level-list">
    <view
      wx:for="{{levels}}"
      wx:key="name"
      class="level-card"
      data-level="{{item.name}}"
      bindtap="goMajors"
    >
      <text class="level-name">{{item.name}}</text>
      <text class="arrow">查看专业</text>
    </view>
  </view>
</view>
