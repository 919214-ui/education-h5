.page {
  padding: 28rpx 28rpx 44rpx;
}

.school-hero,
.level-card,
.school-detail {
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(39, 63, 60, .08);
}

.school-hero {
  padding: 28rpx;
  display: flex;
  gap: 22rpx;
}

.school-logo {
  width: 150rpx;
  height: 180rpx;
  border-radius: 8rpx;
  background: linear-gradient(145deg, #fff0e7 0%, #e9f3f1 100%);
  color: #b94438;
  font-size: 58rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.school-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.share-button {
  width: 100%;
  height: 78rpx;
  margin-top: 18rpx;
  border-radius: 8rpx;
  background: #1f5f5b;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.path {
  font-size: 22rpx;
  color: #8a6a36;
}

.school-name {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.school-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: #596966;
}

.section-head {
  margin: 28rpx 0 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
}

.section-subtitle {
  font-size: 22rpx;
  color: #697a77;
}

.level-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.level-card {
  min-height: 230rpx;
  padding: 34rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.school-detail {
  margin-top: 22rpx;
  min-height: 420rpx;
  padding: 30rpx;
}

.intro-image {
  width: 100%;
  height: 230rpx;
  margin-bottom: 24rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #fff0e7 0%, #f7d7a2 48%, #e9f3f1 100%);
  color: #b94438;
  font-size: 52rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-title {
  display: block;
  font-size: 29rpx;
  font-weight: 900;
}

.detail-text {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #596966;
}

.level-name {
  font-size: 58rpx;
  font-weight: 900;
}

.level-card {
  position: relative;
  min-height: 310rpx;
  padding: 44rpx 30rpx 78rpx;
  background: linear-gradient(135deg, #fff7ea 0%, #f3c26b 100%);
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.level-card:nth-child(2) {
  background: linear-gradient(135deg, #fff3df 0%, #df9d54 100%);
}

.level-card::before {
  content: "";
  position: absolute;
  right: -54rpx;
  top: -54rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, .34);
}

.level-card::after {
  content: "";
  position: absolute;
  left: -44rpx;
  bottom: -60rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(185, 68, 56, .1);
}

.level-name {
  position: relative;
  z-index: 1;
  color: #6b2f22;
  text-align: center;
  font-size: 68rpx;
  letter-spacing: 0;
}

.arrow {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 26rpx;
  z-index: 1;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
  color: #7b3d25;
}
