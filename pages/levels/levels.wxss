.page {
  padding: 28rpx 28rpx 44rpx;
}

.school-summary,
.school-detail,
.major-card,
.empty {
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(39, 63, 60, .08);
}

.school-summary {
  padding: 28rpx;
}

.school-detail {
  margin-top: 22rpx;
  padding: 28rpx;
  overflow: hidden;
}

.detail-title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.school-name {
  font-size: 38rpx;
  font-weight: 900;
}

.school-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: #596966;
}

.section-head {
  margin: 28rpx 0 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
}

.section-subtitle {
  font-size: 22rpx;
  color: #697a77;
}

.major-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.major-card {
  min-height: 156rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.major-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.major-name {
  font-size: 30rpx;
  font-weight: 900;
}

.major-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #596966;
}

.major-side {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.price {
  font-size: 30rpx;
  font-weight: 900;
  color: #b94438;
}

.detail-link {
  margin-top: 8rpx;
  font-size: 23rpx;
  font-weight: 900;
  color: #1f5f5b;
}

.empty {
  padding: 30rpx;
  text-align: center;
  color: #697a77;
}
