.page {
  padding: 28rpx 28rpx 160rpx;
}

.product-hero,
.price-panel,
.detail-card {
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(39, 63, 60, .08);
}

.product-hero {
  padding: 28rpx;
  display: flex;
  gap: 24rpx;
}

.cover {
  width: 176rpx;
  height: 220rpx;
  border-radius: 8rpx;
  background: linear-gradient(145deg, #fff0e7 0%, #e9f3f1 100%);
  color: #b94438;
  font-size: 70rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.path {
  font-size: 22rpx;
  color: #8a6a36;
}

.name {
  margin-top: 14rpx;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #172322;
}

.short {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: #596966;
}

.price-panel,
.detail-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.panel-title,
.detail-title {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
}

.option-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.price-option {
  min-height: 112rpx;
  padding: 20rpx;
  border: 2rpx solid #edf2f1;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.price-option.active {
  border-color: #b94438;
  background: #fffaf0;
}

.level {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
}

.service {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #697a77;
}

.price {
  flex: 0 0 auto;
  font-size: 36rpx;
  font-weight: 900;
  color: #b94438;
}

.detail-text {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: #485956;
}

.service-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.service-item {
  width: 31%;
  min-height: 62rpx;
  border-radius: 8rpx;
  background: #f3f0e8;
  color: #66543b;
  font-size: 23rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.buy-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, .96);
  border-top: 1rpx solid #dde7e5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.bar-label,
.bar-price {
  display: block;
}

.bar-label {
  font-size: 22rpx;
  color: #697a77;
}

.bar-price {
  margin-top: 4rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #b94438;
}

.buy-button {
  width: 188rpx;
  height: 76rpx;
  border-radius: 8rpx;
  background: #b94438;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}
