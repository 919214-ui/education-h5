.page {
  padding: 28rpx 28rpx 44rpx;
}

.price-card,
.card {
  border-radius: 8rpx;
  background: #fff;
  box-shadow: 0 8rpx 28rpx rgba(39, 63, 60, .08);
}

.desc,
.detail,
.service {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #596966;
}

.price-card,
.card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.price-label,
.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
}

.price {
  display: block;
  margin-top: 10rpx;
  font-size: 52rpx;
  font-weight: 900;
  color: #b94438;
}

.service,
.detail {
  display: block;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f0e8;
  color: #66543b;
  font-size: 24rpx;
}
